<!DOCTYPE html>
<html>
<head>
<title>[ Clyde ] AI CORE v1.0</title>

<style>
body {
    margin: 0;
    background: black;
    overflow: hidden;
    font-family: "Courier New", monospace;
    color: #00f7ff;
}

/* MATRIX RAIN CANVAS */
canvas {
    position: fixed;
    top: 0;
    left: 0;
    z-index: -2;
}

/* CRT SCANLINES */
body::after {
    content: "";
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(
        0deg,
        rgba(0,0,0,0.2),
        rgba(0,0,0,0.2) 2px,
        transparent 2px,
        transparent 4px
    );
    pointer-events: none;
    z-index: 10;
}

/* MAIN CONTAINER */
.container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100vh;
}

/* GLITCH TITLE */
.title {
    font-size: 22px;
    margin-bottom: 10px;
    animation: glitch 1s infinite;
}

@keyframes glitch {
    0% { text-shadow: 2px 0 red; }
    50% { text-shadow: -2px 0 blue; }
    100% { text-shadow: 2px 0 red; }
}

/* STATUS */
.status {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
}

.dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #00f7ff;
    box-shadow: 0 0 15px #00f7ff;
    animation: pulse 1.5s infinite;
}

.dot.thinking {
    background: #ff00c8;
    box-shadow: 0 0 20px #ff00c8;
}

@keyframes pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.6); }
    100% { transform: scale(1); }
}

/* CHAT WINDOW */
.chat {
    width: 80ch;
    height: 48em;
    border: 1px solid #00f7ff;
    padding: 10px;
    overflow-y: auto;
    background: rgba(0,0,0,0.6);
    box-shadow: 0 0 20px #00f7ff;
}

/* FLICKER EFFECT */
.bot {
    animation: flicker 0.2s infinite alternate;
}

@keyframes flicker {
    from { opacity: 1; }
    to { opacity: 0.85; }
}

.user { color: #ff00c8; }

.input-area {
    margin-top: 10px;
    width: 80ch;
    display: flex;
}

input {
    flex: 1;
    background: black;
    border: 1px solid #00f7ff;
    color: #00f7ff;
    padding: 8px;
}

button {
    background: #ff00c8;
    border: none;
    padding: 8px 15px;
    font-weight: bold;
}
</style>
</head>

<body>

<canvas id="matrix"></canvas>

<div class="container">

<div class="title">[ Clyde ] AI CORE v1.0</div>

<div class="status">
    <div id="dot" class="dot"></div>
    <div id="statusText">ONLINE</div>
</div>

<div id="chat" class="chat"></div>

<div class="input-area">
    <input id="input" placeholder="ENTER COMMAND..." />
    <button onclick="send()">SEND</button>
</div>

</div>

<script>
// MATRIX RAIN
const canvas = document.getElementById("matrix");
const ctx = canvas.getContext("2d");

canvas.height = window.innerHeight;
canvas.width = window.innerWidth;

const letters = "01";
const fontSize = 14;
const columns = canvas.width / fontSize;
const drops = [];

for (let x = 0; x < columns; x++)
    drops[x] = 1;

function draw() {
    ctx.fillStyle = "rgba(0, 0, 0, 0.05)";
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    ctx.fillStyle = "#00f7ff";
    ctx.font = fontSize + "px monospace";

    for (let i = 0; i < drops.length; i++) {
        const text = letters[Math.floor(Math.random()*letters.length)];
        ctx.fillText(text, i*fontSize, drops[i]*fontSize);

        if (drops[i]*fontSize > canvas.height && Math.random() > 0.975)
            drops[i] = 0;

        drops[i]++;
    }
}
setInterval(draw, 33);

// STREAMING
const chat = document.getElementById("chat");
const dot = document.getElementById("dot");
const statusText = document.getElementById("statusText");

function setThinking(state){
    if(state){
        dot.classList.add("thinking");
        statusText.innerText="PROCESSING";
    } else {
        dot.classList.remove("thinking");
        statusText.innerText="ONLINE";
    }
}

function send(){
    const input = document.getElementById("input");
    const message = input.value;
    if(!message) return;

    chat.innerHTML += `<div class="user">> ${message}</div>`;
    chat.scrollTop = chat.scrollHeight;

    input.value="";
    setThinking(true);

    const botLine = document.createElement("div");
    botLine.className="bot";
    botLine.innerHTML="> ";
    chat.appendChild(botLine);

    const formData = new FormData();
    formData.append("user_message", message);

    fetch("/stream", {
        method:"POST",
        body:formData
    }).then(response=>{
        const reader = response.body.getReader();
        const decoder = new TextDecoder();

        function read(){
            reader.read().then(({done,value})=>{
                if(done){
                    setThinking(false);
                    return;
                }
                const chunk = decoder.decode(value);
                const lines = chunk.split("\n");
                lines.forEach(line=>{
                    if(line.startsWith("data: ")){
                        botLine.innerHTML += line.replace("data: ","");
                        chat.scrollTop = chat.scrollHeight;
                    }
                });
                read();
            });
        }
        read();
    });
}

document.getElementById("input")
.addEventListener("keypress", e=>{
    if(e.key==="Enter") send();
});
</script>

</body>
</html>

